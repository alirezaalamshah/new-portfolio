---
// Social links with inline SVG icons — icons keyed by the `label` in src/data/site.ts.
// `icons` = icon-only round buttons (footer); `buttons` = icon + label pills (contact page).
import { contact } from '../data/site';

interface Props {
  variant?: 'icons' | 'buttons';
}

const { variant = 'icons' } = Astro.props;

const icons: Record<string, string> = {
