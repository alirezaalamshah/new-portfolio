---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import IsoBadge from '../components/IsoBadge.astro';
import { type Lang } from '../i18n';
import { ui } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const projects = (await getCollection('projects', (e) => e.id.startsWith(`${lang}/`))).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout lang={lang} title={t.portfolio.title} description={t.portfolio.metaDescription} path="/portfolio">
  <section class="page">
    <header class="page-head">
      <div class="head-copy">
        <h1>{t.portfolio.title}</h1>
        <p class="lede">{t.portfolio.intro}</p>
      </div>
      <IsoBadge variant="portfolio" />
    </header>
    <div class="grid">
      {projects.map((project) => <ProjectCard lang={lang} project={project} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-block-start: var(--space-6);
  }

  .lede {
    color: var(--text-muted);
    max-width: var(--measure);
    margin-block-end: var(--space-5);
  }
</style>
