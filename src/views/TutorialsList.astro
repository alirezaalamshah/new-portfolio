---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import IsoBadge from '../components/IsoBadge.astro';
import { localizePath, type Lang } from '../i18n';
import { ui } from '../i18n/ui';
import { slugifyTag } from '../lib/tags';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const posts = (await getCollection('tutorials', (e) => e.id.startsWith(`${lang}/`) && !e.data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<BaseLayout lang={lang} title={t.tutorials.title} description={t.tutorials.metaDescription} path="/tutorials">
  <section class="page">
    <header class="page-head">
      <div class="head-copy">
        <h1>{t.tutorials.title}</h1>
        <p class="lede">{t.tutorials.intro}</p>
      </div>
      <IsoBadge variant="tutorials" />
    </header>

    <div class="toolbar">
      <div id="search" class="search-box">
        <input
          type="search"
          id="search-trigger"
          placeholder={t.tutorials.searchPlaceholder}
          aria-label={t.tutorials.searchPlaceholder}
        />
      </div>
      {tags.length > 0 && (
        <ul class="tags" aria-label={t.tutorials.tagLabel}>
          {tags.map((tag) => (
            <li>
              <a class="tag" href={localizePath(lang, `/tutorials/tag/${slugifyTag(tag)}`)}>{tag}</a>
            </li>
          ))}
        </ul>
      )}
    </div>

    <div class="grid">
      {posts.map((post) => <PostCard lang={lang} post={post} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-block-start: var(--space-6);
  }

  .lede {
    color: var(--text-muted);
    max-width: var(--measure);
    margin-block-end: 0;
  }

  .toolbar {
    margin-block: var(--space-4) var(--space-5);
    display: grid;
    gap: var(--space-3);
  }

  .toolbar .tags {
    margin: 0;
  }

  .search-box {
    max-width: 28rem;
  }

  .search-box input[type='search'] {
    width: 100%;
    min-height: 44px;
    padding: 0.5rem 1rem;
    font: inherit;
    color: var(--text);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .search-box input[type='search']::placeholder {
    color: var(--text-muted);
  }

  .search-box input[type='search']:focus {
    border-color: var(--accent);
    outline: none;
  }

  /* pagefind default UI → design tokens */
  .search-box :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg-raised);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--bg-raised);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: var(--font-sans);
  }
</style>

<script>
  // Lazy Pagefind: assets load only when the user engages the search box.
  // Note: /pagefind/ exists only in the built site (npm run build), not in dev.
  const trigger = document.getElementById('search-trigger') as HTMLInputElement | null;
  let started = false;

  async function initSearch() {
    if (started || !trigger) return;
    started = true;

    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = '/pagefind/pagefind-ui.css';
    document.head.appendChild(css);

    try {
      await new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.onload = resolve;
        s.onerror = reject;
        document.body.appendChild(s);
      });
    } catch {
      return; // dev mode: index not built yet
    }

    const query = trigger.value;
    trigger.remove();
    // @ts-expect-error PagefindUI is a global from pagefind-ui.js
    new PagefindUI({ element: '#search', showImages: false, autofocus: true });
    const input = document.querySelector<HTMLInputElement>('#search input');
    if (input && query) {
      input.value = query;
      input.dispatchEvent(new Event('input'));
    }
    input?.focus();
  }

  trigger?.addEventListener('focus', initSearch, { once: true });
</script>
